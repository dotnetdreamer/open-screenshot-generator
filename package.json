{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "node scripts/gen-ai-catalog.mjs && next build",
    "gen:ai-catalog": "node scripts/gen-ai-catalog.mjs",
    "start": "npm run dev",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:extension": "esbuild extension/src/background.ts extension/src/bridge.ts extension/src/adapters/claude.ts extension/src/adapters/chatgpt.ts extension/src/adapters/gemini.ts extension/src/adapters/copilot.ts extension/src/adapters/deepseek.ts extension/src/adapters/qwen.ts extension/src/adapters/perplexity.ts extension/src/adapters/glm.ts --bundle --format=iife --target=chrome110 --outbase=extension/src --outdir=extension/dist",
    "build:assistant-agent": "esbuild src/lib/ai/webAssistantAgent.ts --bundle --format=iife --target=chrome110 --outfile=src-tauri/assistant/agent.js",
    "tauri": "tauri",
    "tauri:dev": "npm run build:assistant-agent && tauri dev",
    "tauri:build": "npm run build:assistant-agent && tauri build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.11",
    "@ai-sdk/google": "^4.0.11",
    "@ai-sdk/openai": "^4.0.10",
