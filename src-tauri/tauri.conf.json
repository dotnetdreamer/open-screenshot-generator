{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Artboard Studio",
  "version": "0.1.1",
  "identifier": "com.ccrstech.artboardstudio",
  "build": {
    "beforeDevCommand": "npm run build:assistant-agent && npm run dev",
    "devUrl": "http://localhost:9002",
    "beforeBuildCommand": "npm run build:assistant-agent && npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Artboard Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "visible": false,
        "backgroundColor": "#E0E0E0"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg", "deb", "appimage"],
    "category": "GraphicsAndDesign",
    "shortDescription": "Device mockup and app screenshot design studio",
    "longDescription": "Artboard Studio lets you compose app store screenshots and device mockups with 3D devices, templates, and a full design canvas.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
