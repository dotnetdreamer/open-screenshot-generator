{
  "manifest_version": 3,
  "name": "Open Screenshot Generator companion",
  "version": "1.0.0",
  "description": "Lets Open Screenshot Generator's AI agent use the Claude, ChatGPT, Gemini, Copilot, DeepSeek, Qwen, Perplexity or GLM (Z.ai) account you are already signed into.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.z.ai/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:9002/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:9002/*",
        "https://editor.openscrgen.app/*",
        "https://openscrgen.app/*",
        "https://*.github.io/*"
      ],
      "js": ["dist/bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/adapters/*.js"],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.z.ai/*"
      ]
    }
  ]
}
